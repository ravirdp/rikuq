const faqs = [
  {
    q: 'Has BatchWise been engaged by LTIMindtree?',
    a: 'No. This is an independent analysis of publicly disclosed financial data from LTIMindtree Limited\'s FY 2024-25 reporting cycle. BatchWise has no engagement with LTIMindtree and makes no claim of delivered work.',
