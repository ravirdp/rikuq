---
import BaseLayout from './BaseLayout.astro';
import ArticleSchema from '@/components/ArticleSchema.astro';
import DisclosureBanner from '@/components/DisclosureBanner.astro';
import NewsletterSignup from '@/components/NewsletterSignup.astro';
import PrismCTA from '@/components/PrismCTA.astro';
import FinOpsCTA from '@/components/FinOpsCTA.astro';
import CitareCTA from '@/components/CitareCTA.astro';
import { SITE, PILLARS } from '@/lib/site';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: keyof typeof PILLARS;
  tags?: string[];
  heroImage?: string;
  ogImage?: string;
  affiliateDisclosure?: boolean;
  prismDisclosure?: boolean;
  citareDisclosure?: boolean;
  batchwiseDisclosure?: boolean;
  faqs?: Array<{ question: string; answer: string }>;
  readingTime?: number;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags = [],
  heroImage,
  ogImage,
  affiliateDisclosure,
  prismDisclosure,
  citareDisclosure,
  batchwiseDisclosure,
  faqs,
  readingTime,
} = Astro.props;

const pillar = PILLARS[category];
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title={title}
  description={description}
  image={ogImage ?? heroImage}
  canonical={canonical}
  type="article"
  publishedTime={pubDate.toISOString()}
  modifiedTime={updatedDate?.toISOString()}
>
  <ArticleSchema
    title={title}
    description={description}
    pubDate={pubDate}
    updatedDate={updatedDate}
    url={canonical}
    image={ogImage ?? heroImage}
    faqs={faqs}
  />

  <article class="container prose">
    <nav aria-label="breadcrumb" class="crumbs">
      <a href="/">rikuq</a> ›
      <a href={`/blog/${pillar.slug}`}>{pillar.title}</a> › <span>{title}</span>
    </nav>

    <header class="post-header">
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      <div class="meta">
        <span>By {SITE.author.name}</span>
        <span>·</span>
        <time datetime={pubDate.toISOString()}>{fmtDate(pubDate)}</time>
        {updatedDate && (
          <>
            <span>·</span>
            <span>Updated {fmtDate(updatedDate)}</span>
          </>
        )}
        {readingTime && (
          <>
            <span>·</span>
            <span>{readingTime} min read</span>
          </>
        )}
      </div>
      {tags.length > 0 && (
        <div class="tags">
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}
    </header>

    {heroImage && (
      <figure class="hero-figure">
        <img src={heroImage} alt="" loading="eager" fetchpriority="high" decoding="async" />
      </figure>
    )}

    <DisclosureBanner
      affiliate={affiliateDisclosure}
      prism={prismDisclosure}
      citare={citareDisclosure}
      batchwise={batchwiseDisclosure}
    />

    <div class="content">
      <slot />
    </div>

    {/* Pillar-driven CTA: infra → Prism, finops → Batchwise advisory, geo → Citare.
        Other categories (tools, stack, essays) get only the newsletter signup. */}
    {category === 'infra' && <PrismCTA variant="card" />}
    {category === 'finops' && <FinOpsCTA variant="card" />}
    {category === 'geo' && <CitareCTA variant="card" />}

    <NewsletterSignup variant="card" />
  </article>
</BaseLayout>

<style>
  .crumbs {
    font-size: 0.85rem;
    color: var(--fg-muted);
    margin: 1.5rem 0 0.5rem;
  }
  .crumbs a {
    color: var(--fg-muted);
    text-decoration: none;
  }
  .post-header {
    margin: 1rem 0 2rem;
  }
  .lede {
    font-size: 1.15rem;
    color: var(--fg-muted);
    margin: 0.5rem 0 1rem;
  }
  .meta {
    font-size: 0.88rem;
    color: var(--fg-muted);
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .tags {
    margin-top: 0.75rem;
  }
  .hero-figure {
    margin: 1.75rem 0 2rem;
    border-radius: 0.85rem;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-subtle);
    aspect-ratio: 16 / 9;
  }
  .hero-figure img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
