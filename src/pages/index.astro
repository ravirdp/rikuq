---
import BaseLayout from '@/layouts/BaseLayout.astro';
import NewsletterSignup from '@/components/NewsletterSignup.astro';
import PillarTile from '@/components/PillarTile.astro';
import PostCard from '@/components/PostCard.astro';
import ProductCard from '@/components/ProductCard.astro';
import { PILLARS, PRODUCTS, SITE } from '@/lib/site';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const featured = sorted[0];
const recent = sorted.slice(1, 7); // up to 6 cards

// Map each pillar to an icon path (drop PNG/SVG into /public/illustrations/pillars/)
// and an emoji fallback that renders today, before images arrive.
const pillarMeta: Record<
  string,
  { icon?: string; emoji: string }
> = {
  tools:  { icon: '/illustrations/pillars/tools.png',  emoji: '⌘' },
  infra:  { icon: '/illustrations/pillars/infra.png',  emoji: '◉' },
  finops: { icon: '/illustrations/pillars/finops.png', emoji: '₿' },
  geo:    { icon: '/illustrations/pillars/geo.png',    emoji: '◐' },
  stack:  { icon: '/illustrations/pillars/stack.png',  emoji: '▦' },
  essays: { icon: '/illustrations/pillars/essays.png', emoji: '✎' },
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author.name,
  url: SITE.url,
  sameAs: SITE.author.sameAs,
  worksFor: PRODUCTS.map((p) => ({
    '@type': 'Organization',
    name: p.name,
    url: p.url,
  })),
};
---

<BaseLayout>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <!-- HERO -->
  <section class="hero container">
    <p class="kicker">A practitioner blog by Ravi · solo founder</p>
    <h1>
      Solo founder.<br />
      Three AI&nbsp;SaaS shipped.<br />
      <span class="accent">Here&rsquo;s how.</span>
    </h1>
    <p class="lede">
      I ship production AI products solo — an OpenAI-compatible gateway, an
      AI-search visibility platform, and an Indian compliance marketplace. This
      blog is the playbook: tool reviews, infra deep-dives, and case studies
      from someone actually building, not theorizing.
    </p>
    <div class="cta">
      <a class="btn" href="/blog">Read the blog</a>
      <a class="btn ghost" href="/about">About Ravi</a>
    </div>
  </section>

  <!-- PILLARS -->
  <section class="container pillars">
    <header class="section-head">
      <h2>What I write about</h2>
      <a href="/blog" class="see-all">All posts →</a>
    </header>
    <div class="pillar-grid">
      {Object.values(PILLARS).map((p) => (
        <PillarTile
          href={`/blog/${p.slug}`}
          title={p.title}
          description={p.description}
          icon={pillarMeta[p.slug]?.icon}
          emoji={pillarMeta[p.slug]?.emoji ?? '✶'}
        />
      ))}
    </div>
  </section>

  <!-- FEATURED + RECENT POSTS -->
  {featured && (
    <section class="container posts">
      <header class="section-head">
        <h2>Latest</h2>
        <a href="/blog" class="see-all">See all posts →</a>
      </header>

      <div class="post-grid">
        <PostCard
          variant="featured"
          href={`/blog/${featured.data.category}/${featured.id}`}
          title={featured.data.title}
          description={featured.data.description}
          category={featured.data.category}
          pubDate={featured.data.pubDate}
          heroImage={featured.data.heroImage}
        />
        {recent.map((p) => (
          <PostCard
            href={`/blog/${p.data.category}/${p.id}`}
            title={p.data.title}
            description={p.data.description}
            category={p.data.category}
            pubDate={p.data.pubDate}
            heroImage={p.data.heroImage}
          />
        ))}
      </div>
    </section>
  )}

  <!-- PRODUCTS -->
  <section class="container products">
    <header class="section-head">
      <h2>Products I ship</h2>
      <a href="/products" class="see-all">All products →</a>
    </header>
    <div class="product-grid">
      {PRODUCTS.map((p) => (
        <ProductCard
          name={p.name}
          by={p.by}
          url={p.url}
          tagline={p.tagline}
          category={p.category}
          logo={p.logo}
        />
      ))}
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="container">
    <NewsletterSignup variant="card" />
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    padding: 5.5rem 1.25rem 3.5rem;
    text-align: left;
    max-width: 56rem;
    margin: 0 auto;
  }
  .kicker {
    margin: 0 0 1rem;
    color: var(--fg-muted);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 7vw, 5.2rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
    font-weight: 400;
  }
  .accent {
    color: var(--accent);
  }
  .lede {
    font-size: 1.1rem;
    color: var(--fg-muted);
    max-width: 42rem;
    margin: 0 0 2rem;
    line-height: 1.55;
  }
  .cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* SECTION SHARED */
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin: 0 0 1.5rem;
    gap: 1rem;
  }
  .section-head h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.6vw, 2.1rem);
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .see-all {
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 0.92rem;
  }
  .see-all:hover {
    color: var(--accent);
  }

  .pillars,
  .posts,
  .products {
    margin-top: 4rem;
  }

  /* PILLAR GRID — 3 across desktop (× 2 rows = 6 pillars), 2 mobile */
  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }
  @media (max-width: 880px) {
    .pillar-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 480px) {
    .pillar-grid {
      grid-template-columns: 1fr;
    }
  }

  /* POSTS GRID — featured spans full row, then 3-up grid */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }
  @media (max-width: 960px) {
    .post-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 600px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }

  /* PRODUCT GRID — 3 across */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }
  @media (max-width: 880px) {
    .product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
