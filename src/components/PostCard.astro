---
import { PILLARS } from '@/lib/site';

interface Props {
  href: string;
  title: string;
  description: string;
  category: keyof typeof PILLARS;
  pubDate: Date;
  heroImage?: string;
  variant?: 'standard' | 'featured';
}
const {
  href,
  title,
  description,
  category,
  pubDate,
  heroImage,
  variant = 'standard',
} = Astro.props;

const pillar = PILLARS[category];
const fmtDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a class:list={['post-card', variant]} href={href}>
  <div class="cover">
    {heroImage ? (
      <img src={heroImage} alt="" loading="lazy" decoding="async" />
    ) : (
      <div class="cover-fallback" aria-hidden="true">
        <span class="cover-pillar">{pillar.title}</span>
      </div>
    )}
  </div>
  <div class="body">
    <span class="pillar-label">{pillar.title}</span>
    <h3>{title}</h3>
    <p class="desc">{description}</p>
    <div class="meta">
      <div class="byline">
        <span class="avatar" aria-hidden="true">R</span>
        <span>Ravi</span>
      </div>
      <span class="sep">·</span>
      <time datetime={pubDate.toISOString()}>{fmtDate}</time>
    </div>
  </div>
</a>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    color: var(--fg);
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 0.85rem;
    overflow: hidden;
    background: var(--bg);
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .post-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
  }
  .cover {
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, #1a1d24, #0f1014);
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }
  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .cover-fallback {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    background:
      radial-gradient(circle at 30% 20%, rgba(245, 185, 66, 0.10), transparent 55%),
      linear-gradient(135deg, #181a20, #0c0d10);
  }
  .cover-pillar {
    font-size: clamp(0.9rem, 1.6vw, 1.1rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
    border: 1px solid var(--border);
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
  }
  .body {
    padding: 1rem 1.1rem 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .pillar-label {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
  }
  h3 {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .desc {
    margin: 0;
    color: var(--fg-muted);
    font-size: 0.88rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.35rem;
    font-size: 0.8rem;
    color: var(--fg-muted);
  }
  .byline {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }
  .avatar {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--accent-fg);
    display: grid;
    place-items: center;
    font-size: 0.7rem;
    font-weight: 700;
  }

  /* Featured variant — full-width hero on homepage */
  .post-card.featured {
    grid-column: 1 / -1;
    flex-direction: row;
    align-items: stretch;
  }
  .post-card.featured .cover {
    flex: 1 1 55%;
    aspect-ratio: auto;
    border-bottom: 0;
    border-right: 1px solid var(--border);
    min-height: 320px;
  }
  .post-card.featured .body {
    flex: 1 1 45%;
    padding: 2rem 2rem;
    justify-content: center;
    gap: 0.7rem;
  }
  .post-card.featured h3 {
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
    line-height: 1.18;
  }
  .post-card.featured .desc {
    -webkit-line-clamp: 4;
    font-size: 0.98rem;
  }
  @media (max-width: 760px) {
    .post-card.featured {
      flex-direction: column;
    }
    .post-card.featured .cover {
      flex: 0 0 auto;
      aspect-ratio: 16 / 9;
      border-right: 0;
      border-bottom: 1px solid var(--border);
      min-height: 0;
    }
    .post-card.featured .body {
      padding: 1.25rem 1.25rem 1.5rem;
    }
  }
</style>
