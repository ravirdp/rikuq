---
// Lead-gen module for Citare — auto-rendered by PostLayout on every
// geo-pillar post. Pillar = product CTA: GEO readers are exactly the
// audience that buys an AI-search visibility platform.

interface Props {
  variant?: 'inline' | 'card';
}
const { variant = 'card' } = Astro.props;

const ctaUrl = 'https://citare.ai?utm_source=rikuq&utm_medium=blog-cta&utm_campaign=geo-pillar';
---

<aside class:list={['citare-cta', variant]} aria-label="Try Citare">
  <div class="header">
    <span class="kicker">By the same builder</span>
    <h3>Citare — AI search visibility, unified</h3>
  </div>

  <p class="lede">
    Track your brand's visibility across ChatGPT, Google AI Overview,
    Gemini, Claude, and Perplexity from one dashboard. Built on the
    four-index reality: each AI engine uses a different underlying
    index, and most legacy SEO tools only watch one.
  </p>

  <ul class="bullets">
    <li><strong>5 AI engines monitored:</strong> ChatGPT, Google AI Overview, Gemini, Claude, Perplexity</li>
    <li><strong>Classical SEO too:</strong> rank tracking, site audit, backlink analysis, keyword research — one platform, not three subscriptions</li>
    <li><strong>19 free tools:</strong> AI readiness checks, schema generators, bot analytics, keyword research</li>
    <li><strong>Native India pricing:</strong> ₹999/mo (INR) or $19/mo (USD), UPI + GST supported</li>
  </ul>

  <div class="actions">
    <a class="btn" href={ctaUrl} rel="me">Try Citare free →</a>
    <span class="actions-note">Free tier: 1 project, 20 free tools. No credit card.</span>
  </div>
</aside>

<style>
  .citare-cta {
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.75rem 1.75rem 1.5rem;
    background: var(--bg-subtle);
    margin: 2.5rem 0;
    position: relative;
    overflow: hidden;
  }
  .citare-cta::before {
    content: '';
    position: absolute;
    bottom: 0;
    right: 0;
    width: 220px;
    height: 220px;
    background: radial-gradient(circle at 100% 100%, rgba(190, 140, 245, 0.10), transparent 60%);
    pointer-events: none;
  }
  .citare-cta.inline {
    background: transparent;
    border-left: 3px solid #be8cf5;
    border-radius: 0;
    padding-left: 1.25rem;
  }
  .header { margin-bottom: 0.6rem; }
  .kicker {
    display: block;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #be8cf5;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }
  h3 {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--fg);
  }
  .lede {
    margin: 0 0 1rem;
    color: var(--fg-muted);
    font-size: 0.96rem;
    line-height: 1.55;
  }
  .bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: grid;
    gap: 0.45rem;
  }
  .bullets li {
    font-size: 0.9rem;
    color: var(--fg-muted);
    line-height: 1.5;
    padding-left: 1.1rem;
    position: relative;
  }
  .bullets li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: #be8cf5;
    font-weight: 700;
    font-size: 1.4rem;
    line-height: 1;
    top: 0;
  }
  .bullets li strong { color: var(--fg); font-weight: 600; }
  .actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem;
  }
  .btn {
    display: inline-block;
    padding: 0.7rem 1.2rem;
    border: 0;
    border-radius: 0.45rem;
    background: #be8cf5;
    color: var(--bg);
    font-weight: 600;
    font-size: 0.92rem;
    text-decoration: none;
  }
  .actions-note { color: var(--fg-muted); font-size: 0.78rem; }
</style>
