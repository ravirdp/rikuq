---
interface Props {
  href: string;
  title: string;
  description: string;
  icon?: string; // path to PNG/SVG, optional
  emoji?: string; // fallback if no icon yet
}
const { href, title, description, icon, emoji } = Astro.props;
---

<a class="pillar-tile" href={href}>
  <div class="pillar-art">
    {icon ? (
      <img src={icon} alt="" loading="lazy" decoding="async" />
    ) : (
      <span class="emoji-fallback" aria-hidden="true">{emoji}</span>
    )}
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
</a>

<style>
  .pillar-tile {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: 0.85rem;
    overflow: hidden;
    background: var(--bg-subtle);
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .pillar-tile:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
  }
  .pillar-art {
    aspect-ratio: 1 / 1;
    background: linear-gradient(135deg, #1a1d24, #0f1014);
    display: grid;
    place-items: center;
    border-bottom: 1px solid var(--border);
  }
  .pillar-art img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .emoji-fallback {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1;
    filter: grayscale(0.2);
  }
  h3 {
    margin: 1rem 1rem 0.35rem;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }
  p {
    margin: 0 1rem 1.1rem;
    color: var(--fg-muted);
    font-size: 0.88rem;
    line-height: 1.45;
  }
</style>
